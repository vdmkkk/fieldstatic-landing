# Copy to `.env` next to the docker-compose.yml on the server and fill in.
# Never commit the real .env — it holds live secrets (this file is a template).

# /admin HTTP Basic Auth password
ADMIN_PASS=change-me

# Waitlist confirmation email — Timeweb mailbox, implicit TLS on port 465.
# Leave SMTP_USER / SMTP_PASS blank to disable email (the site still works).
SMTP_HOST=smtp.timeweb.ru
SMTP_PORT=465
SMTP_USER=noreply@fieldstatic.shop
SMTP_PASS=your-mailbox-password
SMTP_FROM=noreply@fieldstatic.shop
SMTP_FROM_NAME=Fieldstatic
SITE_URL=https://fieldstatic.shop
